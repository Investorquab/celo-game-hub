PORT=4000

# ─────────────────────────────────────────────────────────────
# THE ONE SWITCH: set CELO_CHAIN + CELO_RPC_URL together to move
# between testnet and mainnet. Everything else in this file stays
# the same shape, just with different values.
#
# NOTE: the old Alfajores testnet was retired in 2025/2026 and
# replaced by Celo Sepolia (chain id 11142220). If you deployed
# contracts to Alfajores before, they no longer exist anywhere
# reachable — redeploy to Celo Sepolia first.
# ─────────────────────────────────────────────────────────────

# Testnet (safe, default):
CELO_CHAIN=sepolia
CELO_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Mainnet (real funds — uncomment these two and comment out the testnet
# pair above when you're ready):
# CELO_CHAIN=mainnet
# CELO_RPC_URL=https://forno.celo.org

# Relayer wallet that pays gas for sponsored transactions.
# Fund this address with testnet CELO (https://faucet.celo.org/celo-sepolia)
# while CELO_CHAIN=sepolia, or real CELO once you flip to mainnet.
# NEVER commit this key or reuse a wallet that holds more than you're
# willing to have drained if this server is compromised.
RELAYER_PRIVATE_KEY=0xyour_relayer_private_key

GAME_RESULTS_CONTRACT=0xDeployedGameResultsAddress
PLAYER_REGISTRY_CONTRACT=0xDeployedPlayerRegistryAddress

# Gas sponsorship guardrails
MAX_SPONSORED_TX_PER_PLAYER_PER_DAY=20
MAX_GAS_LIMIT_WEI=500000
TREASURY_LOW_BALANCE_ALERT_CELO=50

DB_PATH=./arcade.db
