# Get a free project ID at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# Backend API base URL
VITE_API_BASE_URL=http://localhost:4000

# Deployed PlayerRegistry address — needed so the app can check/complete
# one-time on-chain registration before a player's first match.
VITE_PLAYER_REGISTRY_CONTRACT=0xYourDeployedPlayerRegistryAddress
